    {
      "parameters": {
        "jsCode": "// We'll check if output is in the strict format\nlet strictFormat = false;\n\ntry {\n  // Must have exactly one item\n  if (items.length === 1 && items[0].json.output && typeof items[0].json.output === 'string') {\n    const parsed = JSON.parse(items[0].json.output);\n\n    const requiredKeys = [\n      \"What's the topic?\",\n      \"Do you know who you want it to sound like?\",\n      \"What is the author name?\",\n      \"Describe the protagonist\",\n      \"submittedAt\",\n      \"formMode\"\n    ];\n\n    // Check all required keys exist AND no extra keys\n    if (\n      typeof parsed === 'object' &&\n      !Array.isArray(parsed) &&\n      requiredKeys.every(k => k in parsed) &&\n      Object.keys(parsed).length === requiredKeys.length\n    ) {\n      strictFormat = true;\n      // Attach parsed JSON to item for downstream nodes\n      items[0].json.parsedOutput = parsed;\n    }\n  }\n} catch (e) {\n  // Parsing failed → not strict format\n}\n\n// Always return items so conversation continues\n// Add a flag indicating whether it's strict or not\nitems[0].json.isStrictFormat = strictFormat;\n\nreturn items;\n"
      },
